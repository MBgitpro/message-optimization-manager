{
  "name": "TeamMember",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Name"
    },
    "email": {
      "type": "string",
      "title": "Email"
    },
    "role": {
      "type": "string",
      "title": "Role",
      "enum": [
        "delivery_lead",
        "project_manager",
        "technical_lead",
        "solutions_architect",
        "account_manager"
      ],
      "default": "delivery_lead"
    },
    "team": {
      "type": "string",
      "title": "Team",
      "enum": [
        "sales",
        "delivery",
        "legal",
        "security",
        "executive"
      ],
      "default": "delivery"
    },
    "max_capacity": {
      "type": "number",
      "title": "Max Active Handoffs",
      "default": 5
    },
    "current_load": {
      "type": "number",
      "title": "Current Active Handoffs",
      "default": 0
    },
    "availability_status": {
      "type": "string",
      "title": "Availability",
      "enum": [
        "available",
        "busy",
        "overloaded",
        "out_of_office"
      ],
      "default": "available"
    },
    "specializations": {
      "type": "string",
      "title": "Specializations"
    },
    "avatar_url": {
      "type": "string",
      "title": "Avatar URL"
    }
  },
  "required": [
    "name",
    "email",
    "role",
    "team"
  ]
}